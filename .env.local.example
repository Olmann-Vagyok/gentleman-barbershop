# ─────────────────────────────────────────────────────────
# Google Calendar Integration
# ─────────────────────────────────────────────────────────
#
# Setup steps:
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "Google Calendar API"
# 3. IAM & Admin → Service Accounts → Create service account
# 4. Generate a JSON key and copy the values below
# 5. Each barber shares their Google Calendar with the
#    service account email (Editor permission)
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─────────────────────────────────────────────────────────
# Barber Google Calendar IDs
# (usually the barber's Google account email)
# ─────────────────────────────────────────────────────────
CALENDAR_ID_MARIAM=mariam@gmail.com
CALENDAR_ID_GEORGE=george@gmail.com
CALENDAR_ID_NABI=nabi@gmail.com
CALENDAR_ID_RAOUL=raoul@gmail.com
CALENDAR_ID_SIDA=sida@gmail.com
